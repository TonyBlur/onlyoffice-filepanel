# Example .env for onlyoffice-filepanel

# Document Server URL reachable by the browser.
DOC_SERVER_URL=http://localhost:8380

# Address Document Server uses to call this app from inside its container/network.
DOC_SERVER_INTERNAL_HOST=http://host.docker.internal:3000

# Must match the JWT secret configured in ONLYOFFICE Document Server.
DOC_SERVER_JWT_SECRET=hUQTo541dF2UjKzO56Ux9jHOD62csevJ

# Admin password for the file panel.
ADMIN_PASSWORD=admin123

# Host port for this app. Container port is always 3000.
APP_EXTERNAL_PORT=3000

# Optional host path for persistent uploaded files.
# If omitted, docker compose uses the named volume files_data.
# HOST_FILES_PATH=C:/onlyoffice-files

# Image used by docker-compose.yml (when using pre-built images).
OOFP_IMAGE=ghcr.io/tonyblur/onlyoffice-filepanel:latest
