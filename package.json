{
  "name": "onlyoffice-filepanel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/server.js",
    "build": "node scripts/clean-dist.js && tsc && vite build --config web/vite.config.ts",
    "build:server": "tsc",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "ts-node server.ts",
    "dev:web": "vite --config web/vite.config.ts"
  },
  "dependencies": {
    "antd": "^5.27.4",
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mime": "^3.0.0",
    "multer": "^2.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^15.7.3",
    "react-router-dom": "6.14.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime": "^3.0.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^6.3.5"
  }
}
