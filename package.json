{
  "name": "onlyoffice-filepanel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/server.js",
    "build": "node scripts/clean-dist.js && tsc && npm --prefix web run build && node scripts/copy-web-build.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "ts-node server.ts",
    "dev:web": "cd web && npm start"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mime": "^3.0.0",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime": "^3.0.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
